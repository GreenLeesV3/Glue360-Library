# --- Build outputs (the app itself) ---
build/
standalone/
out/
cmake-build-*/
[Bb]in/
[Oo]bj/

# --- Compiled artifacts ---
*.exe
*.dll
*.lib
*.obj
*.pdb
*.ilk
*.exp
*.idb
*.map
*.tlog
*.lastbuildstate

# --- CMake / Ninja intermediates ---
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
.ninja_deps
.ninja_log
build.ninja
rules.ninja

# --- Pipeline runtime outputs (created per-run under the workspace) ---
user_data/
extracted/
.recomp/
generated/
sdk-src/
logs/

# --- SDK source snapshots (fetched per-run; never vendored) ---
rexglue-sdk-*/
sdk-source/
*-source-code/
RexGlue360Recomp-source/

# --- IDE / editor ---
.vs/
.vscode/
.idea/
*.user
*.suo
*.sln.docstates
*.opensdf
*.sdf
*.VC.db
*.VC.VC.opendb

# --- OS cruft ---
Thumbs.db
desktop.ini
.DS_Store

# --- Local state / secrets ---
*.local
*.secret
.env
.env.*
